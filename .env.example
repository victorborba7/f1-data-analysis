# Copy to .env and fill in. The tasks runner and dbt read these.
# .env is gitignored — never commit real values or the key file.

# --- BigQuery ---------------------------------------------------------------
GCP_PROJECT=your-gcp-project-id
BQ_DATASET_RAW=f1_raw
BQ_DATASET_ANALYTICS=f1_analytics
BQ_LOCATION=US

# Path to a service-account JSON key with BigQuery Data Editor + Job User.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# --- dbt ---------------------------------------------------------------------
DBT_TARGET=dev

# --- Jolpica (optional overrides) -------------------------------------------
# JOLPICA_BASE_URL=https://api.jolpi.ca/ergast/f1
# JOLPICA_MIN_INTERVAL_S=0.27
# F1_FIRST_SEASON=1950
# F1_PITSTOPS_FIRST_SEASON=2011
