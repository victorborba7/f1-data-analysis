# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# FastF1 cache (large binary files, re-downloaded automatically)
**/f1_cache/
**/content/f1_cache/

# Generated media (too large for git — store on Google Drive / share link in post)
*.mp4
*.avi
*.gif

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Secrets
.env
# Service-account keys / GCP credentials — NEVER commit
*-sa.json
*service-account*.json
gcp-key*.json

# ELT: raw API response cache + local parquet staging (regenerable)
extract/.cache/
extract/.stage/

# dbt build artifacts (target = compiled SQL + run results; packages = installed deps)
transform/target/
transform/dbt_packages/
transform/logs/
transform/.user.yml
# dbt parses profiles.yml from env vars, so the committed copy is safe; a local
# override with real secrets is not — ignore it.
transform/profiles.local.yml

# Claude Code tooling
.claude/

# Quarto build output (rendered by CI; _freeze/ IS committed)
/_site/
.quarto/
