#!/usr/bin/env sh
# Enforce Conventional Commits on the subject line.
# Configured via: git config core.hooksPath .githooks

commit_msg_file="$1"
first_line=$(head -n1 "$commit_msg_file")

# Let merge/revert/fixup/squash commits through unchecked
case "$first_line" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9 ._/-]+\))?(!)?: .{1,100}$'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

{
  echo "✗ Commit message does not follow Conventional Commits."
  echo
  echo "  Format: <type>(<optional scope>): <subject>"
  echo "  Types : feat fix docs style refactor perf test build ci chore revert"
  echo
  echo "  Examples:"
  echo "    feat(barcelona): add tyre degradation analysis"
  echo "    fix(site): correct scss layer boundary"
  echo "    docs: update README setup steps"
  echo
  echo "  Your subject: $first_line"
} >&2
exit 1
